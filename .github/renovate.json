{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "automergeStrategy": "rebase",
  "automergeType": "pr",
  "enabledManagers": ["npm", "github-actions", "dockerfile", "pre-commit"],
  "extends": ["config:best-practices", ":enablePreCommit"],
  "ignoreUnstable": true,
  "labels": ["automated", "dependencies"],
  "packageRules": [
    {
      "addLabels": ["javascript"],
      "matchManagers": ["npm"],
      "respectLatest": true
    },
    {
      "groupName": "npm dependencies",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "groupName": "typescript",
      "matchPackageNames": ["typescript", "ts-node", "@types/*"]
    },
    {
      "groupName": "eslint",
      "matchPackageNames": ["eslint*", "@eslint/*"]
    },
    {
      "groupName": "react",
      "matchPackageNames": ["react", "react-dom", "@types/react*"]
    },
    {
      "groupName": "testing",
      "matchPackageNames": [
        "@testing-library/*",
        "vitest",
        "@vitest/*",
        "jsdom"
      ]
    },
    {
      "groupName": "vite",
      "matchPackageNames": ["vite", "@vitejs/*"]
    },
    {
      "addLabels": ["gh-actions"],
      "commitMessagePrefix": "Actions:",
      "matchManagers": ["github-actions"],
      "prConcurrentLimit": 2
    },
    {
      "groupName": "github-actions dependencies",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "dependencyDashboardApproval": true,
      "matchDepNames": ["python"],
      "matchManagers": ["github-actions"],
      "separateMultipleMinor": true
    },
    {
      "addLabels": ["docker"],
      "commitMessagePrefix": "Docker:",
      "matchFileNames": ["docker/**"],
      "matchManagers": ["dockerfile"],
      "prConcurrentLimit": 2
    },
    {
      "groupName": "docker dependencies",
      "matchFileNames": ["docker/**"],
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "enabled": false,
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["python"],
      "matchUpdateTypes": ["major", "minor"]
    },
    {
      "addLabels": ["pre-commit hooks"],
      "commitMessagePrefix": "Chore: pre-commit:",
      "matchManagers": ["pre-commit"],
      "prConcurrentLimit": 1,
      "schedule": ["* 2-5 1-7 * 1"]
    },
    {
      "groupName": "pre-commit hooks",
      "matchManagers": ["pre-commit"],
      "matchUpdateTypes": ["minor", "patch"]
    }
  ],
  "platformAutomerge": true,
  "schedule": ["* 2-5 * * 1"],
  "timezone": "Etc/UTC",
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["automated", "dependencies", "security"]
  }
}
