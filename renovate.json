{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["npm"],
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "ignoreUnstable": true,
      "respectLatest": false
    },
    {
      "matchPackageNames": ["eslint*", "@eslint/*"],
      "groupName": "eslint"
    },
    {
      "matchPackageNames": ["react", "react-dom", "@types/react*"],
      "groupName": "react"
    },
    {
      "matchPackageNames": [
        "@testing-library/*",
        "vitest",
        "@vitest/*",
        "jsdom"
      ],
      "groupName": "testing"
    },
    {
      "matchPackageNames": ["vite", "@vitejs/*"],
      "groupName": "vite"
    }
  ]
}
