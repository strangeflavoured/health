{
  "semi": false,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "overrides": [
    {
      "files": ["**/*.ts", "**/*.tsx"],
      "options": {
        "plugins": ["./frontend/node_modules/@trivago/prettier-plugin-sort-imports"],
        "importOrder": [
          "^react",
          "<THIRD_PARTY_MODULES>",
          "^[./]"
        ],
        "importOrderSeparation": true,
        "importOrderSortSpecifiersWithinImportDeclarations": true
      }
    }
  ]
}
