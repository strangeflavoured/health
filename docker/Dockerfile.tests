# syntax=docker/dockerfile:1.24@sha256:87999aa3d42bdc6bea60565083ee17e86d1f3339802f543c0d03998580f9cb89
FROM python:3.12-slim-bookworm@sha256:93ab4b7fa528b25124c97bcc755415e60eb671a86b4dbe0328df2fe2d1c1193d AS base

# Install system dependencies
RUN rm -f /etc/apt/apt.conf.d/docker-clean && \
    echo 'Binary::apt::APT::Keep-Downloaded-Packages "true";' \
      > /etc/apt/apt.conf.d/keep-cache

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get dist-upgrade --yes -V

# create user
RUN useradd --create-home --uid 1000 health
USER health
WORKDIR /home/health/

# Install requirements
COPY --chown=health:health ./tests/requirements.txt .
COPY --chown=health:health ./pip-requirements.txt .
ENV PATH="/home/health/.local/bin:$PATH"
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --user --require-hashes -r pip-requirements.txt && \
    pip install --user --require-hashes -r requirements.txt

COPY --chown=health:health ./pyproject.toml .

FROM base AS src-test
COPY --chown=health:health ./src ./src
COPY --chown=health:health ./versions.json .
COPY --chown=health:health ./tests .

ENTRYPOINT ["python3", "-m", "pytest"]
CMD ["--cov=src", "--cov-report=term-missing:skip-covered", "--cov-fail-under=80"]

FROM base AS scripts-test
COPY --chown=health:health ./scripts ./scripts

ENTRYPOINT ["python3", "-m", "pytest"]
