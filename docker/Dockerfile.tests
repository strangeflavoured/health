# syntax=docker/dockerfile:1.24@sha256:87999aa3d42bdc6bea60565083ee17e86d1f3339802f543c0d03998580f9cb89
FROM ghcr.io/astral-sh/uv:0.11.21-python3.12-trixie-slim@sha256:54c1de8440cebd445b38c4b0cdbc733f1efffbced64c1da2c96a8f10453fcffa AS base

RUN useradd --create-home --uid 1000 health
USER health
WORKDIR /home/health

ENV UV_CACHE_DIR=/home/health/.cache/uv \
    UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PYTHON_DOWNLOADS=never \
    PYTHONUNBUFFERED=1 \
    PATH="/home/health/.venv/bin:$PATH"

# Dependency layer
COPY --chown=health:health pyproject.toml uv.lock ./
RUN uv sync --locked --no-dev --group test --no-install-project

# Project layer — venv is finalised here, so prune cache in the same RUN
COPY --chown=health:health ./src ./src
COPY --chown=health:health versions.json README.md ./
RUN uv sync --locked --no-dev --group test --no-editable \
    && rm -rf /home/health/.cache/uv


FROM base AS src-test
COPY --chown=health:health ./tests ./tests
ENTRYPOINT ["uv", "run", "--frozen", "-m", "pytest"]
CMD ["--cov=src", "--cov-report=term-missing:skip-covered", "--cov-fail-under=80"]


FROM base AS scripts-test
COPY --chown=health:health ./scripts ./scripts
ENTRYPOINT ["uv", "run", "--frozen", "-m", "pytest"]
