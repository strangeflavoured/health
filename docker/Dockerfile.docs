# syntax=docker/dockerfile:1.25@sha256:0adf442eae370b6087e08edc7c50b552d80ddf261576f4ebd6421006b2461f12
FROM ghcr.io/astral-sh/uv:0.11.24-python3.12-trixie-slim@sha256:ca785de25138ba9a68fc85ce818efa8de6555501df1b6d14b086efbe0893d699 AS base

# Install system dependencies
RUN rm -f /etc/apt/apt.conf.d/docker-clean && \
    echo 'Binary::apt::APT::Keep-Downloaded-Packages "true";' \
      > /etc/apt/apt.conf.d/keep-cache

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install --yes --no-install-recommends make nodejs npm && apt-get dist-upgrade --yes -V

RUN useradd --create-home --uid 1000 health
RUN mkdir -p /home/health/.cache/uv && chown -R health:health /home/health
USER health
WORKDIR /home/health

ENV UV_CACHE_DIR=/home/health/.cache/uv \
    UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PYTHON_DOWNLOADS=never \
    PYTHONUNBUFFERED=1 \
    PATH="/home/health/.venv/bin:$PATH"

# Dependency layer
COPY --chown=health:health pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/home/health/.cache/uv,uid=1000,gid=1000,sharing=shared \
    uv sync --locked --no-dev --group backend --group docs --no-install-project

# Project layer
COPY --chown=health:health versions.json README.md ./
COPY --chown=health:health ./src ./src
RUN --mount=type=cache,target=/home/health/.cache/uv,uid=1000,gid=1000,sharing=shared \
    uv sync --locked --no-dev --group backend --group docs --no-editable

# install npm deps
COPY --chown=health:health ./frontend/package.json ./frontend/package-lock.json ./frontend/
RUN --mount=type=cache,target=/home/health/.npm,uid=1000,gid=1000,sharing=shared \
    cd frontend && npm ci --ignore-scripts

COPY --chown=health:health ./CHANGELOG.md ./CONTRIBUTING.md ./MAINTAINERS.md ./ROADMAP.md /CODE_OF_CONDUCT.md ./
COPY --chown=health:health ./frontend/src ./frontend/src
COPY --chown=health:health ./backend/apps ./backend/apps
COPY --chown=health:health ./docs ./docs

ENTRYPOINT ["make", "-C", "docs", "clean", "html"]
